{
  "name": "wechat-rpa-bot",
  "version": "1.0.0",
  "description": "微信 RPA 机器人 - Node.js/TypeScript 版本。使用 RPA 技术控制微信桌面客户端，支持消息发送、朋友圈管理、群发等自动化功能。",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "service:start": "node dist/scripts/start-service.js",
    "service:stop": "node dist/scripts/stop-service.js",
    "test": "jest"
  },
  "keywords": [
    "wechat",
    "rpa",
    "automation",
    "bot",
    "微信",
    "机器人"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "express": "^4.18.2",
    "ws": "^8.14.2",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.3.2",
    "ts-node": "^10.9.2"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}